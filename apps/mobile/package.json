{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "node -e \"process.env.EXPO_NO_TELEMETRY='1'; const r=require('child_process').spawnSync('npx',['expo-doctor','.'],{stdio:'inherit',shell:true}); process.exit(r.status ?? 1)\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --ci --runInBand",
    "validate:bundle": "node -e \"process.env.EXPO_NO_TELEMETRY='1'; const r=require('child_process').spawnSync('npx',['expo','export','--platform','android','--output-dir','.expo/ci-export','--no-bytecode'],{stdio:'inherit',shell:true}); process.exit(r.status ?? 1)\"",
    "prebuild:android": "node -e \"process.env.EXPO_NO_TELEMETRY='1'; const r=require('child_process').spawnSync('npx',['expo','prebuild','--platform','android','--clean','--no-install'],{stdio:'inherit',shell:true}); process.exit(r.status ?? 1)\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.100.1",
    "expo": "~54.0.34",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "expo-doctor": "^1.16.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "private": true
}
